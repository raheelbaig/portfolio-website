# Copy to .env.local and fill in. All variables are optional in Milestone 1.

# Canonical site origin (used for metadata / canonical URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AI Attendant (later milestone; absence = attendant stays off) ---
# Model provider key for /api/attendant.
ANTHROPIC_API_KEY=
# Hard daily spend ceiling in USD; crossing it auto-disables the attendant.
ATTENDANT_DAILY_BUDGET_USD=
